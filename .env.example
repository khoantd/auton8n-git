# =============================================================================
# Supabase (frontend + backend)
# For Vercel: set both in Project → Settings → Environment Variables.
# In Supabase: Authentication → URL Configuration, add your Vercel URL to
# Site URL and Redirect URLs to avoid AuthRetryableFetchError.
# App tables live in schema "app". In Dashboard → Settings → API, add "app"
# to Exposed schemas so the API can access them.
# =============================================================================
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# =============================================================================
# PayPal — frontend (Vite / browser)
# Get credentials from https://developer.paypal.com/
# Use SANDBOX client ID for testing; use LIVE client ID for production.
# Must match backend PAYPAL_ENV: sandbox client ID with PAYPAL_ENV=sandbox.
# =============================================================================
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
VITE_PAYPAL_CURRENCY=USD
VITE_PAYPAL_INTENT=capture

# Base URL of your Express backend (where create-order / capture-order live)
VITE_API_BASE_URL=http://localhost:4000

