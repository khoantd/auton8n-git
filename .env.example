# =============================================================================
# Backend API (MySQL)
# Frontend talks to your backend at VITE_API_BASE_URL.
# In local dev with Vite, /api is proxied to this URL.
# =============================================================================
VITE_API_BASE_URL=http://localhost:4000

# =============================================================================
# PayPal — frontend (Vite / browser)
# Get credentials from https://developer.paypal.com/
# Use SANDBOX client ID for testing; use LIVE client ID for production.
# Must match backend PAYPAL_ENV: sandbox client ID with PAYPAL_ENV=sandbox.
# =============================================================================
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
VITE_PAYPAL_CURRENCY=USD
VITE_PAYPAL_INTENT=capture

# Base URL of your Express backend (where payment and admin routes live)
# VITE_API_BASE_URL=http://localhost:4000

